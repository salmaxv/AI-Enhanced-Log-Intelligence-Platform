# This .gitignore file is used to specify intentionally untracked files that Git should ignore. 
# It helps to keep the repository clean by excluding files that are not necessary to be tracked, such as environment files, logs, and dependencies.

# Environment files 
.env
backend/.env
frontend/.env

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.venv/
venv/
env/
ENV/

# Logs
*.log

# Node
node_modules/
dist/

# VS Code / OS
.vscode/
.DS_Store
Thumbs.db

# Coverage
.coverage
htmlcov/

